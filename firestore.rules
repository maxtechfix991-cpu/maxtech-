rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users Collection Rules ---
    match /users/{userId} {
      allow read, write: if true;
    }

    // --- Bots Collection Rules ---
    match /bots/{botId} {
      allow read, write: if true;
    }

    // --- Positions Collection Rules ---
    match /positions/{positionId} {
      allow read, write: if true;
    }

    // --- Logs Collection Rules ---
    match /logs/{logId} {
      allow read, write: if true;
    }

    // --- Audit Log Collection Rules ---
    match /audit_log/{auditId} {
      allow read, write: if true;
    }
  }
}
